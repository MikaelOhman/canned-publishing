  "html": "<p>\u0000\u0003\u0000\u0004\u0000\u0005\u0000\u0006 \u0000\u0007\u0000\b\u0000</p><p>\u0000 \u0000\u0006\u0000\u000b\u0000\f\u0000 \u0000\u000e\u0000\u000f\u0000\u000e\u0000\u0010\u0000\u0011\u0000\b\u0000\b\u0000\u0011\u0000\b\u0000\u0012 \u0000 \u0000\u0004\u0000\u0006\u0000\u0013\u0000\u0004\u0000\u0014\u0000\u0015\u0000\u0013\u0000\u0016 \u0000\u0017\u0000\u0003\u0000\u0002\u0000\u000e\u0000\u0010\u0000\u0011\u0000\u0018\u0000\u000e\u0000\u0010</p><p>Postadress Gatuadress Telefon E-post Hemsida Organisationsnummer \u0000\u0019\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u001b\u0000\u0014\u0000\u0013\u0000\u001c\u0000\u001d\u0000\u0002\u0000\u001a\u0000\u001e\u0000\r\u0000\r\u0000\f\u0000\u0015 \u0000\u0012\u0000\b\u0000\u001f\u0000\u0002\u0000 \u0000\b\u0000\u0002\u0000!\u0000&quot;\u0000\f\u0000\u001c\u0000\u0014\u0000\u001d\u0000\u000b\u0000\u0006 \u0000#\u0000\u0006\u0000\u0015\u0000\u001c\u0000\u0006\u0000\u000b\u0000\u0006\u0000\u0015\u0000\u0002\u0000\u0012 \u0000!\u0000&quot;\u0000\f\u0000\u001c\u0000\u0014\u0000\u001d\u0000\u000b\u0000\u0006 \u0000\u000f\u0000\u0010\u0000 \u0000\u0010\u0000\u0011\u0000$\u0000 \u0000\u0012\u0000\u0002\u0000\u000f\u0000\u000f \u0000\u001a\u0000\u001e\u0000\u0015\u0000\u000b\u0000\u0006\u0000\u001a\u0000\u000b\u0000%\u0000\u0014\u0000\u0015\u0000\u000b\u0000\u0014\u0000\u0013\u0000&amp;\u0000’\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u001b\u0000\u0014\u0000\u0013\u0000\u001c\u0000\u0016\u0000\u001d\u0000\u0014 \u0000’\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u001b\u0000\u0014\u0000\u0013\u0000\u001c\u0000\u0016\u0000\u001d\u0000\u0014 \u0000\u000e\u0000\b\u0000\u000e\u0000\u000f\u0000\u000f\u0000\u000f\u0000\u0011\u0000\u000e\u0000(\u0000 \u0000\b</p><p>\u0000)\u0000\u001e\u0000’\u0000*\u0000\u0002\u0000\u0003\u0000+\u0000\u0013\u0000\u0014\u0000\u0015\u0000\u0002\u0000,\u0000\u001d\u0000\u000b\u0000’\u0000\f\u0000\u0015\u0000\u0005\u0000\u0002\u0000-\u0000\u0006\u0000\u0013\u0000’\u0000\u001e\u0000</p><p>\u0000.\u0000\u0014\u0000&quot;\u0000\u0002\u0000)\u0000\u001e\u0000’\u0000*\u0000/\u0000\u0002</p><p>\u00000\u0000\u0006\u0000%\u0000\u001a\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u0002\u0000\u0005\u0000\u0004\u0000\u000b\u0000\u000b\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u001d\u0000’\u0000\u0006\u0000\u001c\u0000\u0002\u0000\u001e\u0000\r\u0000\u0002\u0000\u0006\u0000\u000b\u0000\u000b\u0000\u0002\u0000\u0006\u0000\u0015\u0000\u001e\u0000\u0013\u0000\u0005\u0000\u0015\u0000\u0006\u0000\u0002\u0000\r\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u000b\u0000\u0014\u0000\u0006\u0000\u000b\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u0004\u0000\u0002\u0000\u001a\u0000\u001e\u0000\r\u0000\r\u0000\f\u0000\u0015\u0000\u0014\u0000\u0015\u00001</p><p>\u0000\u0019\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u001b\u0000\u0014\u0000\u0013\u0000\u001c\u0000\u001d\u0000\u0002\u0000\u001a\u0000\u001e\u0000\r\u0000\r\u0000\f\u0000\u0015\u0000\u0002\u0000\u0006\u0000\u0015\u0000\u001d\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u0006\u0000\u000b\u0000\u000b\u0000\u0002\u0000\u0005\u0000\u0014\u0000\u000b\u0000\u0002\u00002\u0000\u0013\u0000\u0002\u00003\u0000\u0004\u0000\u001a\u0000\u000b\u0000\u0004\u0000\u001c\u0000\u000b\u0000\u0002\u0000\u0006\u0000\u000b\u0000\u000b\u0000\u0002\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0002\u0000*\u00004\u0000\u0013\u0000\u0002\u0000\f\u00005\u00005\u0000’\u0000\u0014\u00003\u0000\u0006\u0000\u0002\u0000\u001a\u0000\f\u0000’\u0000\u000b\u0000\f\u0000\u0013\u0000\u0002\u0000\u001e\u0000%\u00006\u0000\u0002\u0000\u001d\u0000\u0006\u0000\u000b\u0000\u001d\u0000\u0006\u0000\u0013\u0000\u0002\u0000\u0013\u0000\u0014\u0000\u0005\u0000\u0006\u0000\u0015\u0000\u0002\u0000\u0004\u0000\u0005\u0000\u0006 \u0000\u0006\u0000\u001a\u0000\u000b\u0000\u0004\u00003\u0000\u0004\u0000\u000b\u0000\u0014\u0000\u000b\u0000\u0014\u0000\u0013\u0000\u0002\u0000\r\u0000\u0014\u0000\u0005\u0000\u0002\u0000\u000b\u0000\u0014\u0000\u0006\u0000\u000b\u0000\u0014\u0000\u0013\u0000\u0004\u0000\u0015\u0000\u001d\u0000’\u0000\u0006\u0000\u001c\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u0002\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0002\u0000\u0004\u0000\u0002\u0000\u0005\u0000\u0014\u0000\u0002\u0000’\u00002\u0000\u001c\u0000\u0013\u0000\u0014\u0000\u0002\u00004\u0000’\u0000\u0005\u0000\u0013\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0006\u0000\u0016</p><p>\u0000!\u0000+\u0000\u0013\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u001d\u0000\u001a\u0000\u001e\u0000’\u0000\u0014\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0002\u0000\u0006\u0000\u0015\u0000\u001e\u0000\u0013\u0000\u0005\u0000\u0015\u0000\u0006\u0000\u001d\u0000\u0002\u0000\u0013\u0000\u0014\u0000\u001c\u0000\u0014\u0000’\u0000\u001b\u0000\f\u0000\u0015\u0000\u0005\u0000\u0014\u0000\u000b\u0000\u0002\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u000b\u0000\u0014\u0000\u0006\u0000\u000b\u0000\u0014\u0000\u0013\u0000*\u0000+\u0000\u0013\u0000\u0014\u0000\u001d\u0000\u000b\u00002\u0000’\u0000’\u0000\u0015\u0000\u0004\u0000\u0015\u0000\u001c\u0000\u0006\u0000\u0013\u0000\u0016\u0000\u0002\u0000 \u00004\u0000\u0002\u0000\u001a\u0000+\u00005\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u001a\u0000\u001e\u0000\r\u0000\r\u0000\f\u0000\u0015\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u0004\u0000\u0015\u0000\u0002 \u00005\u0000\u0013\u0000\u001e\u0000*\u0000\u0014\u0000\u001d\u0000\u001d\u0000\u0004\u0000\u001e\u0000\u0015\u0000\u0014\u0000’\u0000’\u0000\u0006\u0000\u0002\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u000b\u0000\u0014\u0000\u0006\u0000\u000b\u0000\u0014\u0000\u0013\u0000\u001c\u0000\u0013\u0000\f\u00005\u00005\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u001d\u0000\u001e\u0000\r\u0000\u0002\u0000\u001d\u00005\u0000\u0014\u0000’\u0000\u0006\u0000\u0013\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u0002\u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0002\u0000\u0004\u0000\u0002\u0000$\u0000\u0011\u0000\u0010\u0000\u0002\u00004\u0000\u0013\u0000\u001d\u00004\u0000’\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0015\u0000\u0016\u0000\u0002\u0000\u0003\u0000\u0014\u0000\u0015\u0000\u0006\u0000\u001d\u0000\u000b\u0000\u0002\u00006\u0000+\u0000’\u0000’\u0000\u001d\u0000\u0002\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u001d\u00004 \u0000*\u0000+\u0000\u0013\u0000\u0014\u0000\u001d\u0000\u000b\u00002\u0000’\u0000’\u0000\u0015\u0000\u0004\u0000\u0015\u0000\u001c\u0000\u0002\u0000\u0004\u0000\u0002\u0000\u001d\u0000’\u0000\f\u0000\u000b\u0000\u0014\u0000\u000b\u0000\u0002\u0000\u0006\u00003\u0000\u0002\u0000\u001d\u0000\u0014\u00005\u0000\u000b\u0000\u0014\u0000\r\u0000\u001b\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u0004\u0000\u0002\u0000\u0019\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u001b\u0000\u0014\u0000\u0013\u0000\u001c\u0000\u001d\u0000\u001a\u00007\u0000\u0013\u0000\u001a\u0000\u0006\u0000\u0015\u0000\u0016\u0000\u0002</p><p>\u0000#\u0000\u0004\u0000\u001b\u0000’\u0000\u0004\u0000\u001e\u0000\u000b\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u000b\u0000\u0002\u0000\u0014\u0000\u0013\u0000\u001b\u0000&quot;\u0000\f\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u001e\u0000%\u0000\u001a\u0000\u001d\u00004\u0000\u0002\u0000\u001d\u0000\u0006\u0000\u001c\u0000\u001e\u0000\u001d\u0000\u000b\u0000\f\u0000\u0015\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0002\u0000\r\u0000\u0014\u0000\u0005\u0000\u0002\u0000\r\u00007\u0000%\u0000\u001a\u0000\u0014\u0000\u000b\u0000\u0002\u0000*\u0000\u0006\u0000\u0015\u0000\u000b\u0000\u0006\u0000\u001d\u0000\u0004\u0000\u0002\u0000\u001e\u0000%\u00006\u0000\u0002\u0000’\u0000\u0014\u0000\u001a\u0000\u0016\u0000\u0002\u0000\u0003\u0000\u0006\u0000\u001c\u0000\u001e\u0000\u0013\u0000\u0015\u0000\u0006\u0000\u0002\u0000\u001b\u0000\u0014\u0000\u0013\u00002\u0000\u000b\u0000\u000b\u0000\u0006\u0000\u001d\u0000\u0002\u0000*\u0000\u0013\u0000\u0004\u0000 \u00006\u0000&quot;\u00002\u0000’\u00005\u0000\u0002\u0000\u0006\u00003\u0000\u0002\u00006\u0000\u0006\u0000\u0015\u0000\u0005\u0000\u0005\u0000\u001e\u0000%\u0000\u001a\u0000\u001e\u0000\u0013\u0000/\u0000\u0002\u0000\u001c\u0000\u001e\u0000\u001d\u0000\u0014\u0000\u0005\u0000&quot;\u0000\f\u0000\u0013\u0000\u0002\u0000\u001e\u0000%\u00006\u0000\u0002\u0000\u0014\u0000\u0015\u0000\u001a\u0000’\u0000\u0006\u0000\u0002\u0000\f\u0000\u000b\u0000\u001a\u0000’\u00002\u0000\u0005\u0000\u0015\u0000\u0006\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0016\u0000\u0002\u0000#\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0014\u0000\u0015\u0000\u0002\u0000*\u00004\u0000\u0013\u0000\u0002\u0000\u001c\u00002\u0000\u0013\u0000\u0015\u0000\u0006\u0000\u0002\u00003\u0000\u0006\u0000\u0013\u0000\u0006\u0000\u0002\u0000\r\u0000\u0014\u0000\u0005\u0000\u0002\u0000\u001e\u0000%\u00006\u0000\u0002\u0000\u0005\u0000\u0000\u001b\u0000\u0014\u0000\u0013\u00002\u0000\u000b\u0000\u000b\u0000\u0014\u0000’\u0000\u001d\u0000\u0014\u0000\u0015\u0000\u0016</p><p>\u0000\u0003\u0000\u0006\u0000\u001c\u0000\u001e\u0000\u001d\u0000\u000b\u0000\f\u0000\u0015\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0015\u0000\u0006\u0000\u0002\u00006\u00004\u0000’\u0000’\u0000\u001d\u0000\u0002\u0000*\u0000\u0013\u0000\u0006\u0000\r\u0000*\u0000+\u0000\u0013\u0000\u0002\u0000\u0006\u0000’\u0000’\u0000\u000b\u0000\u0002\u00005\u00004\u0000\u0002\u0000!\u0000\u0006\u0000\r\u0000\u0004\u0000’\u0000&quot;\u0000\u0014\u0000%\u0000\u0014\u0000\u0015\u0000\u000b\u0000\u0013\u0000\u0006\u0000’\u0000\u0014\u0000\u0015\u0000/\u0000\u0002\u0000*\u00007\u0000\u0013\u0000\u0006\u0000\u0002\u0000\u001c\u00004\u0000\u0015\u0000\u001c\u0000\u0014\u0000\u0013\u0000\u0002\u00005\u00004\u0000\u0002\u00003\u00004\u0000\u0013\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u001e\u0000%\u00006\u0000\u0002\u0000*\u00007\u0000\u0013\u0000\u0006 \u0000\u001e\u0000%\u00006\u0000\u0002\u0000\u0005\u0000\u0014\u0000\u001d\u0000\u001d\u0000\f\u0000\u000b\u0000\u001e\u0000\r\u0000\u0002\u00003\u0000\u0004\u0000\u0005\u0000\u0002\u0000\u0003\u00003\u0000\u0014\u0000\u0015\u0000\u001d\u0000\u001a\u0000\u0006\u0000\u0002\u0000\u001a\u00007\u0000\u0013\u0000\u001a\u0000\u0006\u0000\u0015\u0000\u001d\u0000\u0002\u0000+\u00005\u00005\u0000\u0015\u0000\u0006\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u001d\u0000\u001a\u0000\u001e\u0000’\u0000\u001e\u0000\u0013\u0000\u0002\u0000\u0004\u0000\u0002\u0000!\u0000&quot;\u0000\f\u0000\u001c\u0000\u0014\u0000\u001d\u0000\u000b\u0000\u0006\u0000/\u0000\u0002\u0000.\u0000\u0004\u0000\u0005\u0000\u0004\u0000\u0015\u0000\u001c\u0000\u0014\u0000\u0002\u0000\u001e\u0000%\u00006\u0000\u0002\u00008\u0000\f\u0000’\u0000’\u00006\u00007\u0000\u000b\u0000\u000b\u0000\u0006\u0000\u0015\u0000\u0002\u00009 \u0000\u000b\u0000\u0014\u0000\u0013\u0000\r\u0000\u0004\u0000\u0015\u0000\u0002\u00005\u00004\u0000\u0002\u00003\u0000\u0006\u0000\u0013\u0000&quot;\u0000\u0014\u0000\u0002\u0000\u001e\u0000\u0013\u0000\u000b\u0000\u0016\u0000\u0002\u0000:\u00004\u0000\u0002\u0000\u001d\u0000\u001e\u0000\r\u0000\r\u0000\u0006\u0000\u0013\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u001e\u0000\u0013\u0000\u0005\u0000\u0015\u0000\u0006\u0000\u001d\u0000\u0002\u00002\u00003\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u001d\u0000\u0006\u0000\u001c\u0000\u001e\u0000\u001d\u0000\u000b\u0000\f\u0000\u0015\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0002\u0000\f\u0000\u000b\u0000\u001e\u0000\r\u00006\u0000\f\u0000\u001d\u0000\u0002\u0000\u0004\u0000\u0002\u0000\u001d\u0000\u0006\u0000\r\u0000\u0006\u0000\u0013\u0000\u001b\u0000\u0014\u0000\u000b\u0000\u0014\u0000\u0002\u0000\r\u0000\u0014\u0000\u0005\u0000\u0002 \u0000!\u0000\u0006\u0000\r\u0000\u0004\u0000’\u0000&quot;\u0000\u0014\u0000%\u0000\u0014\u0000\u0015\u0000\u000b\u0000\u0013\u0000\u0006\u0000’\u0000\u0014\u0000\u0015\u0000/\u0000\u0002\u0000\u001e\u0000*\u0000\u000b\u0000\u0006\u0000\u0002\u0000\u0004\u0000\u0002\u0000’\u0000\u0014\u0000\u001a\u00005\u0000\u0006\u0000\u0013\u0000\u001a\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u0004\u0000\u0002\u0000!\u0000&quot;\u0000\f\u0000\u001c\u0000\u0014\u0000\u001d\u0000\u000b\u0000\u0006\u0000\u0016\u0000\u0002\u0000;\u0000\u0006\u0000\u0013\u0000&quot;\u0000\u0014\u0000\u0002\u00003\u00004\u0000\u0013\u0000\u0002\u0000\u001b\u0000&quot;\u0000\f\u0000\u0005\u0000\u0014\u0000\u0013\u0000\u0002\u0000\u001b\u0000\u0004\u0000\u001b\u0000’\u0000\u0004\u0000\u001e\u0000\u000b\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u000b\u0000\u0002\u0000\u0005\u0000\u0014\u0000\u001d\u0000\u001d\u0000\f\u0000\u000b\u0000\u001e\u0000\r\u0000\u0002\u0000\u0004\u0000\u0015\u0000\u0002\u0000\u0005\u0000\u0014 \u0000\u001b\u0000\u0006\u0000\u0013\u0000\u0015\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u0004\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u001d\u0000\u001a\u0000\u001e\u0000’\u0000\u0006\u0000\u0015\u0000\u0002\u0000\u000b\u0000\u0004\u0000’\u0000’\u0000\u0002\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u001d\u00002\u0000\u0013\u0000\u001d\u0000\u001a\u0000\u0004\u0000’\u0000\u0005\u0000\u0002\u0000\u0005\u0000\u0013\u0000\u0006\u0000\r\u0000\u0006\u0000\u000b\u0000\u0004\u0000\u001d\u0000\u0014\u0000\u0013\u0000\u0006\u0000\u0005\u0000\u0002\u0000\u001d\u0000\u0006\u0000\u001c\u0000\u001e\u0000\u001d\u0000\u000b\u0000\f\u0000\u0015\u0000\u0005\u0000\u0002\u00005\u00004\u0000\u0002\u0000\u001b\u0000\u0004\u0000\u001b\u0000’\u0000\u0004\u0000\u001e\u0000\u000b\u0000\u0014\u0000\u001a\u0000\u0014\u0000\u000b\u0000\u0016</p><p>\u00000\u0000\u0004\u0000\u0005\u0000\u0004\u0000\u001c\u0000\u0006\u0000\u0013\u0000\u0014\u0000\u0002\u00006\u0000\u0006\u0000\u0013\u0000\u0002\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u0004\u0000\u0005\u0000\u0014\u0000\u0014\u0000’\u0000’\u0000\u0002\u0000*\u0000+\u0000\u0013\u0000\u0014\u0000\u0015\u0000\u0004\u0000\u0015\u0000\u001c\u0000\u0002\u0000\u0004\u0000\u0002\u0000\u001a\u0000\u001e\u0000\r\u0000\r\u0000\f\u0000\u0015\u0000\u0014\u0000\u0015\u0000\u0002\u0000\u001e\u0000%\u0000\u001a\u0000\u001d\u00004\u0000\u0002\u