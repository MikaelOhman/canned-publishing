{
  "_om": "Uttalslager för TTS (sv). Appliceras BARA på texten som matas till röstmotorn – synlig text/manus rörs aldrig. 'ersattningar': förkortn./symboler → utläsning (skiftlägesokänsligt för ord, literal för symboler, längst nyckel först). 'regler': regex (monster→ersatt) körs efter ersattningar, före siffernormaliseringen i kod. 'flaggade': ord som lät fel vid provlyssning + fonetisk fix (får vara medvetet 'felstavade' om det låter rätt). Siffror/år normaliseras i _normalisera_tal().",
  "ersattningar": {
    "%": " procent",
    "&": " och ",
    "kr": "kronor",
    "kr.": "kronor",
    "mnkr": "miljoner kronor",
    "mdkr": "miljarder kronor",
    "t.ex.": "till exempel",
    "t ex": "till exempel",
    "bl.a.": "bland annat",
    "m.m.": "med mera",
    "m fl": "med flera",
    "m.fl.": "med flera",
    "d.v.s.": "det vill säga",
    "dvs": "det vill säga",
    "t.o.m.": "till och med",
    "o.s.v.": "och så vidare",
    "osv": "och så vidare",
    "fr.o.m.": "från och med",
    "ca": "cirka",
    "ca.": "cirka",
    "nr": "nummer",
    "kap.": "kapitel",
    "VAB": "vård av barn",
    "RiR": "Riksrevisionens rapport",
    "SFS": "svensk författningssamling",
    "BNP": "bee enn pee",
    "EU": "ee uu"
  },
  "regler": [
    {"monster": "(?<![0-9:])([0-9]{4}):([0-9]{1,4})(?![0-9:])", "ersatt": "\\1 kolon \\2", "_om": "SFS/RiR-nr 2003:1156 -> '2003 kolon 1156' (siffrorna talform-as sen i kod)"},
    {"monster": "([0-9]+)\\s*§§", "ersatt": "paragraferna \\1", "_om": "'5 §§' -> 'paragraferna 5'"},
    {"monster": "§§\\s*([0-9]+)", "ersatt": "paragraferna \\1", "_om": "'§§ 5' -> 'paragraferna 5'"},
    {"monster": "([0-9]+)\\s*§", "ersatt": "paragraf \\1", "_om": "'5 §' -> 'paragraf 5' (svensk läsordning)"},
    {"monster": "§\\s*([0-9]+)", "ersatt": "paragraf \\1", "_om": "'§ 5' -> 'paragraf 5'"},
    {"monster": "§§", "ersatt": "paragraferna", "_om": "lös §§"},
    {"monster": "§", "ersatt": "paragraf", "_om": "lös §"}
  ],
  "flaggade": []
}
